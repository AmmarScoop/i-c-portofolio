# Database (SQLite by default for zero-config local dev)
# To use PostgreSQL / Supabase instead, change provider in prisma/schema.prisma to "postgresql"
# and set DATABASE_URL to your Supabase/Postgres connection string, e.g.:
# DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"
DATABASE_URL="file:./dev.db"

# NextAuth
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Supabase Storage, used for session "product photo" uploads
# (see src/lib/storage.ts). If left blank, uploads are written to
# public/uploads/session-products/ on the local filesystem instead — no setup
# required, works out of the box. Set both of the vars below to switch to
# Supabase Storage instead:
#   1. Create a Storage bucket named "session-products" in your Supabase project.
#   2. Mark it Public (Storage -> session-products -> Settings -> Public bucket).
#   3. Copy your project URL and service role key below.
# (Also usable more generally if you switch the DB provider itself to
# Supabase/Postgres — see "Switching to PostgreSQL/Supabase" in the README.)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Seed script default admin credentials (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@academy.test"
SEED_ADMIN_PASSWORD="Admin123!"
